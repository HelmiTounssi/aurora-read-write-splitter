# Configuration Aurora AWS pour AuroraReadWriteSplitter
# Copiez ce fichier vers aurora-config.env et remplacez les valeurs par vos vraies informations Aurora

# ===========================================
# ENDPOINTS AURORA AWS
# ===========================================

# Endpoint pour les opérations d'écriture (Writer Endpoint)
# Format: your-cluster-name.cluster-xxxxx.region.rds.amazonaws.com
AURORA_WRITER_ENDPOINT=your-cluster-name.cluster-xxxxx.region.rds.amazonaws.com

# Endpoint pour les opérations de lecture (Reader Endpoint)
# Format: your-cluster-name.cluster-ro-xxxxx.region.rds.amazonaws.com
AURORA_READER_ENDPOINT=your-cluster-name.cluster-ro-xxxxx.region.rds.amazonaws.com

# ===========================================
# INFORMATIONS DE BASE DE DONNÉES
# ===========================================

# Nom de la base de données Aurora
DB_NAME=your_database_name

# Nom d'utilisateur Aurora (Master Username)
DB_USERNAME=your_username

# Mot de passe Aurora (Master Password)
DB_PASSWORD=your_secure_password

# ===========================================
# CONFIGURATION OPTIONNELLE
# ===========================================

# Port de la base de données (par défaut 3306 pour MySQL)
DB_PORT=3306

# Région AWS où se trouve votre cluster Aurora
AWS_REGION=your-aws-region

# ===========================================
# INSTRUCTIONS D'UTILISATION
# ===========================================

# 1. Copiez ce fichier : cp aurora-config.example.env aurora-config.env
# 2. Remplacez toutes les valeurs "your-..." par vos vraies informations Aurora
# 3. Sauvegardez le fichier aurora-config.env
# 4. Assurez-vous que aurora-config.env est dans .gitignore (déjà configuré)

# ===========================================
# EXEMPLE DE CONFIGURATION RÉELLE
# ===========================================

# Exemple (à remplacer par vos vraies valeurs) :
# AURORA_WRITER_ENDPOINT=my-aurora-cluster.cluster-abc123.us-east-1.rds.amazonaws.com
# AURORA_READER_ENDPOINT=my-aurora-cluster.cluster-ro-abc123.us-east-1.rds.amazonaws.com
# DB_NAME=my_database
# DB_USERNAME=admin
# DB_PASSWORD=MySecurePassword123!
# AWS_REGION=us-east-1 